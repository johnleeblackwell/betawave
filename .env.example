# ─── βWave — paste the key(s) for the model(s) you want ─────────────────────
# You only need ONE LLM key. Anthropic (Claude) is the default.
ANTHROPIC_API_KEY=

# Custom OpenAI-compatible endpoint — works with GLM-5 (Zhipu AI), Groq,
# Together AI, LM Studio, LocalAI, Mistral, Fireworks, or any local model.
# Example (GLM-5): CUSTOM_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Example (Groq):  CUSTOM_LLM_BASE_URL=https://api.groq.com/openai/v1
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# ─── OPENCODE ZEN — Big Pickle fallback ──────────────────────────────────────
# When Anthropic returns a 529 overloaded error, βWave automatically retries
# using Big Pickle (opencode's stealth model, free during beta).
# Get your key at https://opencode.ai/auth → add billing → API key.
OPENCODE_ZEN_API_KEY=

# Login protection — set a password to enable the login page.
# Leave blank (or omit) for no auth (InTurn default for local use).
APP_PASSWORD=

# Server
PORT=3001

# ─── TURSO — embedded replica sync (optional) ────────────────────────────────
# Leave blank for local-only SQLite (single-machine). Set both to bind the
# local data.db as an embedded replica that syncs bidirectionally with Turso.
# Get these from https://turso.tech → Database → Connect.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: Arweave / Irys upload for Colony Agent sites
# Set your Solana wallet private key (base58) to enable permanent storage on Arweave.
# Paid in SOL (~$0.008 per colony site). Leave blank to save locally only.
IRYS_PRIVATE_KEY=

# ─── MCP SERVER — Model Context Protocol (Claude Desktop / remote) ───────────
# The βWave MCP server (mcp/) exposes clients, pipeline, invoices & syndication
# as tools+resources to Claude. Two transports: stdio (local, no config needed)
# and Streamable HTTP (remote microservice). See README-MCP.md.
#
# HTTP transport port (default 3030).
MCP_HTTP_PORT=3030
# Shared bearer token for the HTTP transport AND for the MCP server to reach the
# main /api when running in HttpClient mode. Leave blank for local-only (open).
# Generate: openssl rand -hex 32
MCP_SERVICE_TOKEN=
# Set to switch the MCP data layer from embedded (in-process db) to HTTP-wrapper.
# e.g. http://localhost:3001  — requires MCP_SERVICE_TOKEN to match the main app.
BWAVE_API_URL=
# OAuth 2.1 (marketplace) — skeleton, inert until issuer is set.
MCP_OAUTH_ISSUER=
MCP_OAUTH_AUDIENCE=
MCP_OAUTH_JWKS_URL=

# ─── NETLIFY — Astro deploy target ──────────────────────────────────────────
# Personal access token from netlify.com → User Settings → Applications → Personal access tokens.
# βWave uses this to create sites, push deploys, and check status — no dashboard needed.
NETLIFY_ACCESS_TOKEN=

# Optional: Email sending (for newsletters)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=Your Agency <your@email.com>

# Ops alerts — where βWave emails YOU when something silently breaks
# (e.g. syndication blocked by provider billing). Falls back to SMTP_USER if unset.
ALERT_EMAIL=

# Optional: Kit (ConvertKit) integration for aim.report lead capture
# Leave blank to keep leads only in the local DB.
KIT_API_KEY=
KIT_FORM_ID=

# ─── WHITE-LABEL BRANDING ────────────────────────────────────────────────────
# All VITE_ vars are baked in at build time (Vite replaces them).
# Leave blank to use InTurn defaults.

# Identity
VITE_BRAND_NAME=InTurn
VITE_BRAND_TAGLINE=Your content, in turn.
VITE_BRAND_LOGO_URL=          # URL to logo image (replaces text + emoji if set)

# Primary accent colour — used for buttons, active tabs, focus rings, hover states
VITE_BRAND_PRIMARY=#d97706
VITE_BRAND_PRIMARY_DARK=#b45309
VITE_BRAND_PRIMARY_LIGHT=#fef3c7
VITE_BRAND_PRIMARY_GLOW=rgba(217,119,6,0.12)

# Sidebar
VITE_SIDEBAR_BG=#0f172a
VITE_SIDEBAR_BORDER=#1e293b
VITE_SIDEBAR_ACTIVE_BG=#1e3a5f
VITE_SIDEBAR_TEXT=#94a3b8
VITE_SIDEBAR_TEXT_ACTIVE=#f8fafc

# Typography (any valid CSS font-family string)
VITE_BRAND_FONT=-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif

# Shape (any valid CSS length — e.g. 4px for sharper, 16px for pill-style)
VITE_BRAND_RADIUS=8px
VITE_BRAND_RADIUS_SM=6px
VITE_BRAND_RADIUS_LG=12px

# ─── MEASURE MODULE — Citation Tracker ───────────────────────────────────────
# Required for Citation Tracker to query all four AI engines.
# OPENAI_API_KEY is also used above for DALL-E 3 image generation.

# OpenAI — gpt-4o-search-preview (web-search grounded)
OPENAI_API_KEY=

# Perplexity — sonar-pro (always-online, grounded by default)
PERPLEXITY_API_KEY=

# Google Gemini — gemini-2.0-flash with Google Search grounding
GEMINI_API_KEY=
